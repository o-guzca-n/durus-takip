from flask import Flask, request, jsonify, render_template_string
from datetime import datetime
import os

app = Flask(__name__)

HTML = """
<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Duruş Takip</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:Arial,sans-serif;background:#1a1a2e;color:#eee;padding:1.2rem;min-height:100vh}
.header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.2rem;flex-wrap:wrap;gap:8px}
.header h1{font-size:18px;font-weight:700;color:#fff}
.badge{font-size:12px;padding:4px 12px;border-radius:8px}
.badge.red{background:#3a0f0f;color:#ff6b6b;border:1px solid #ff6b6b}
.badge.green{background:#0f3a1a;color:#51cf66;border:1px solid #51cf66}
.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px;margin-bottom:1.2rem}
.card{background:#16213e;border-radius:10px;padding:.875rem;border:1px solid #2a2a4a}
.card .lbl{font-size:11px;color:#888;margin-bottom:4px}
.card .val{font-size:22px;font-weight:700;color:#fff}
.card .val.red{color:#ff6b6b}
.card .val.amber{color:#f0a500}
.sec{background:#16213e;border:1px solid #2a2a4a;border-radius:12px;padding:1rem;margin-bottom:1rem}
.sec h2{font-size:14px;font-weight:700;color:#f0a500;margin-bottom:.875rem}
.live-box{display:flex;align-items:center;gap:10px;padding:.75rem;border-radius:8px;border:1px solid #2a2a4a;background:#0f1628;margin-bottom:8px}
.dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
