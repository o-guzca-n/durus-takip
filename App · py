tr:last-child td{border-bottom:none}
tr:hover td{background:#0f1628}
.pill{display:inline-block;font-size:11px;padding:2px 8px;border-radius:20px}
.pill.red{background:#3a0f0f;color:#ff6b6b;border:1px solid #ff6b6b}
.pill.green{background:#0f3a1a;color:#51cf66;border:1px solid #51cf66}
</style>
</head>
<body>
<div class="header">
  <h1>⚠️ Duruş Takip Sistemi</h1>
  <span id="badge" class="badge green">Yükleniyor</span>
</div>
<div class="cards">
  <div class="card"><div class="lbl">Toplam Duruş</div><div class="val" id="cToplam">—</div></div>
  <div class="card"><div class="lbl">Toplam Süre</div><div class="val amber" id="cToplamSure">—</div></div>
  <div class="card"><div class="lbl">Ort. Süre</div><div class="val" id="cOrt">—</div></div>
  <div class="card"><div class="lbl">Aktif Duruş</div><div class="val red" id="cAktif">—</div></div>
</div>
<div class="sec">
  <h2>🔴 Canlı Durum</h2>
  <div id="liveDiv">Yükleniyor...</div>
</div>
<div class="sec">
  <h2>📋 Geçmiş Kayıtlar</h2>
  <div style="overflow-x:auto">
    <table>
      <thead><tr><th>Tarih</th><th>Saat</th><th>İstasyon</th><th>Süre</th><th>Durum</th></tr></thead>
      <tbody id="tabloBody"></tbody>
    </table>
  </div>
</div>
<script>
function fmt(sn){return Math.floor(sn/60)+" dk "+(sn%60)+" sn"}
async function veriCek(){
  try{
    const res=await fetch("/api");
    const data=await res.json();
    const aktifSayisi=data.istasyonlar.filter(i=>i.aktif).length;
    const badge=document.getElementById("badge");
    badge.textContent=aktifSayisi>0?aktifSayisi+" Aktif Duruş":"Tümü Çalışıyor";
    badge.className=aktifSayisi>0?"badge red":"badge green";
    let toplamSn=0,toplamDurus=0;
    data.istasyonlar.forEach(i=>{toplamSn+=i.toplam_sn;toplamDurus+=i.kayit_sayisi;});
    const ort=toplamDurus>0?Math.round(toplamSn/toplamDurus):0;
    document.getElementById("cToplam").textContent=toplamDurus;
    document.getElementById("cToplamSure").textContent=fmt(toplamSn);
    document.getElementById("cOrt").textContent=fmt(ort);
    document.getElementById("cAktif").textContent=aktifSayisi;
    let liveHTML="";
    data.istasyonlar.forEach(ist=>{
      const aktif=ist.aktif;
      liveHTML+=`<div class="live-box">
        <div class="dot ${aktif?'red':'green'}"></div>
        <div><div class="live-name">${ist.isim}</div>
        <div class="live-sub">${aktif?'Duruş devam ediyor':'Son duruş: '+fmt(ist.son_sure_sn)}</div></div>
        <div class="live-time ${aktif?'red':'green'}">${aktif?fmt(ist.aktif_sure_sn):'Çalışıyor'}</div>
      </div>`;
    });
    document.getElementById("liveDiv").innerHTML=liveHTML||"<div style='color:#888'>Henüz veri yok</div>";
    let tabloHTML="";
    data.kayitlar.forEach(k=>{
      tabloHTML+=`<tr><td>${k.tarih}</td><td>${k.saat}</td><td>${k.istasyon}</td>
        <td>${fmt(k.sure_sn)}</td>
        <td><span class="pill ${k.aktif?'red':'green'}">${k.aktif?'Aktif':'Tamamlandı'}</span></td></tr>`;
    });
    document.getElementById("tabloBody").innerHTML=tabloHTML||
      "<tr><td colspan='5' style='text-align:center;color:#888;padding:1rem'>Henüz kayıt yok</td></tr>";
  }catch(e){console.error(e)}
}
veriCek();
setInterval(veriCek,5000);
</script>
