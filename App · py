# RAM'de tutulan veri yapısı
istasyonlar = {}

@app.route("/")
def index():
    return render_template_string(HTML)

@app.route("/veri", methods=["POST"])
def veri_al():
    data = request.get_json(force=True)
    if not data:
        return jsonify({"status": "error", "msg": "JSON bekleniyor"}), 400

    isim = data.get("isim", "Bilinmiyor")

    if isim not in istasyonlar:
        istasyonlar[isim] = {
            "isim": isim,
            "aktif": False,
            "aktif_sure_sn": 0,
            "son_sure_sn": 0,
            "kayit_sayisi": 0,
            "toplam_sn": 0,
            "kayitlar": []
        }

    ist = istasyonlar[isim]
    ist["aktif"]         = data.get("aktif", False)
    ist["aktif_sure_sn"] = data.get("sure_sn", 0)

    # Duruş bitti → kayıt ekle
    if not ist["aktif"] and data.get("sure_sn", 0) > 0:
        sure_sn = data["sure_sn"]
        ist["son_sure_sn"]  = sure_sn
        ist["kayit_sayisi"] += 1
        ist["toplam_sn"]    += sure_sn
        ist["kayitlar"].insert(0, {
            "tarih"   : datetime.now().strftime("%d.%m.%Y"),
            "saat"    : datetime.now().strftime("%H:%M:%S"),
            "istasyon": isim,
            "sure_sn" : sure_sn,
            "aktif"   : False
        })
        if len(ist["kayitlar"]) > 100:
            ist["kayitlar"].pop()

    return jsonify({"status": "ok"})

@app.route("/api")
def api():
    tum_kayitlar = []
    for ist in istasyonlar.values():
        tum_kayitlar.extend(ist["kayitlar"])
    tum_kayitlar.sort(key=lambda x: x["tarih"] + x["saat"], reverse=True)
    return jsonify({
        "istasyonlar": list(istasyonlar.values()),
        "kayitlar"   : tum_kayitlar[:50]
    })

@app.route("/health")
def health():
    return jsonify({"status": "ok"})

if __name__ == "__main__":
    port = int(os.environ.get("PORT", 5000))
    app.run(host="0.0.0.0", port=port, debug=False)
